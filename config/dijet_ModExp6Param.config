combine_parameters = ['Ntot_bkg_PFDijet2024[3.3e8]',
                   'p0_PFDijet2024[1]','p1_PFDijet2024[-58.]','p2_PFDijet2024[0.12]','p3_PFDijet2024[0.01]','p4_PFDijet2024[-0.08]','p5_PFDijet2024[0.01]',
                   'sqrts[13600]',
                   'PFDijet2024_bkg_norm[1]',
                   'meff_PFDijet2024[-1]','seff_PFDijet2024[-1]']

combine_pdfs = ['RooModExp6ParamBinPdf::PFDijet2024_bkg(th1x,p1_PFDijet2024,p2_PFDijet2024,p3_PFDijet2024,p4_PFDijet2024,p5_PFDijet2024,sqrts)',
                "EXPR::PFDijet2024_bkg_unbin('p0_PFDijet2024*exp(p1_PFDijet2024*pow(mjj/sqrts,p2_PFDijet2024) + p3_PFDijet2024*pow(1.0-mjj/sqrts,p4_PFDijet2024)*(1+p5_PFDijet2024*(mjj/sqrts)))',mjj,p0_PFDijet2024,p1_PFDijet2024,p2_PFDijet2024,p3_PFDijet2024,p4_PFDijet2024,p5_PFDijet2024,sqrts)",
                'SUM::extDijetPdf(Ntot_bkg_PFDijet2024*PFDijet2024_bkg)']

signal_mjj = [565, 606, 649, 693, 740, 788, 838, 890, 944, 1000, 1058, 1118, 1181, 1246, 1313, 1383, 1455, 1530, 1607, 1687, 1770, 1856, 1945, 2037, 2132]
